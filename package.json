{
  "name": "@ponelat/backlogger",
  "private": false,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:hosted": "BACKLOGGER_VITE_BASE=/backlogger/ npm run build && node --import tsx server/dev-server.ts",
    "build:spa": "vite build --outDir dist/spa",
    "build:cli": "tsc -p tsconfig.node.json && chmod +x dist/server/cli.js",
    "build": "rm -rf dist && npm run build:cli && npm run build:spa",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepack": "npm run build",
    "cli": "tsx server/cli.ts"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^5.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.18.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "bin": {
    "backlogger": "dist/server/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
